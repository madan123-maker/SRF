{
  "name": "srf-management-platform-workspace",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "install:frontend": "npm install --prefix frontend",
    "install:backend": "npm install --prefix backend",
    "install-all": "node node_modules/concurrently/dist/bin/concurrently.js \"npm run install:frontend\" \"npm run install:backend\"",
    "server": "npm run start --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "dev": "node node_modules/concurrently/dist/bin/concurrently.js \"npm run server\" \"npm run frontend\"",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
